# Merriam-Webster Dictionary API Key
# Used by both projects for word definitions
MW_API_KEY=your_merriam_webster_api_key_here

# Anthropic API Key (for traditional_speech_art project)
# Used for Claude Sonnet 4.5
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for voice2voice_web project)
# Used for Realtime API
OPENAI_API_KEY=your_openai_api_key_here

# Access codes for voice2voice_web (comma-separated list)
# These are the codes users must enter to authenticate
ACCESS_CODES=your-access-code-1,your-access-code-2,your-access-code-3
